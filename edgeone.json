{
  "headers": [
    {
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "source": "/owo.json"
    },
    {
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "source": "/api/*"
    },
    {
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/atom+xml"
        }
      ],
      "source": "/atom.xml"
    },
    {
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ],
      "source": "*.opml"
    }
  ],
  "redirects": [
    {
      "source": "/sitemap.xml/",
      "destination": "/sitemap.xml",
      "statusCode": 308
    }
  ]
}
